<!--new scroll sidebar start-->
<style>
    /*new scroll css*/
    #news-updates {
  height: 200px; /* Fixed height */
  overflow: hidden; /* Hide content that overflows */
  position: relative;
}

.news-item {
  margin: 10px 0;
  /* Add some styling for the anchor tags if needed */
}
</style>
<script>
$(document).ready(function() {
  var $news = $('#news-updates');
  var $newsItems = $news.children();  // Get all news items
  var itemHeight = $newsItems.first().outerHeight(true); // Get the height of a single news item including margin
  var totalHeight = $newsItems.length * itemHeight; // Total height of all items combined

  // Clone the news items to create an infinite scroll effect
  $news.append($newsItems.clone());

  function scrollNews() {
    // Perform the animation from the current scroll position to the total height
    $news.animate(
      { scrollTop: totalHeight }, // Scroll to the bottom of the content
      10000, // Duration for the scroll (adjust speed here)
      'linear', // Continuous linear scrolling
      function() {
        // After scrolling to the end, reset scroll position and start over
        $news.scrollTop(0);
        scrollNews(); // Restart the scroll
      }
    );
  }

  scrollNews(); // Initiate the scrolling
});


</script>
