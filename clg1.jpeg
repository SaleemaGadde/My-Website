    <script>
    $(document).ready(function() {
        $('#pdfModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget); // Button that triggered the modal
            var pdfUrl = button.data('pdf'); // Extract info from data-* attributes

            var modal = $(this);
            modal.find('#pdfIframe').attr('src', pdfUrl);
        });

        $('#pdfModal').on('hide.bs.modal', function (event) {
            var modal = $(this);
            modal.find('#pdfIframe').attr('src', ''); // Clear the src when hiding the modal
        });
    });
    </script>
